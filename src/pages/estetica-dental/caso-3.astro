---
import Footer from "../../components/Footer.astro";
import Gallery from "../../components/Gallery.astro";
import ListaServices from "../../components/ListaServices.astro";
import NavBar from "../../components/NavBar.astro";
import Whatsapp from "../../components/Whatsapp.astro";
import Layout from "../../layouts/Layout.astro";
import { caso3 } from "../../const/Cases/Dental-Stetic/case3";
---

<Layout title="Estetica Dental">
  <NavBar />

  <div class="p-14 bg-black"></div>

  <div class="w-full py-16 px-4 md:px-8 overflow-hidden">
    <div class="flex flex-col md:flex-row items-center gap-12">
      <div class="flex flex-1 justify-center items-center gap-2">
        <Gallery casos={caso3} />
      </div>

      <div
        class="flex-1 flex flex-col items-center md:items-start text-center md:text-left gap-2"
      >
        <h2 class="text-3xl md:text-4xl font-bold">
          Tienes espacios entre tus dientes mira este caso
        </h2>

        <span>#SonrisasRealesIntegradent</span>
        <p class="text-gray-600 leading-relaxed text-justify justify-normal">
          Nuestra querida paciente acudió a nosotros para recuperar su sonrisa
          por mala práctica en una endodoncia en su diente, afectando el color y
          oscureciéndolo. Lamentablemente estos casos son muy comunes y lo peor
          es que los afectados son los pacientes, que generan una falta de
          confianza al no poder sonreír libremente afectando su autoestima. En
          este caso se realizó:
        </p>
        <ul class="text-gray-600">
          <li>✅Retratamiento de endodoncia pieza 21</li>
          <li>✅Blanqueamiento interno</li>
          <li>✅Blanqueamiento externo</li>
          <li>✅Restauración estética</li>
        </ul>
      </div>
      <ListaServices />
    </div>
  </div>

  <Whatsapp />
  <Footer />
</Layout>
